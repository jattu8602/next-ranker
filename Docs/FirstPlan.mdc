can you give me a prisma schema

Since you’re building Next-Ranker (a test-series platform), your Prisma schema should support:

Categories

Subcategories

Exams

Test Series

Tests

Questions

Users

Attempts

This structure will scale to 1000+ exams and millions of attempts.

Below is a production-ready Prisma schema design.

🧩 Prisma Schema (Next-Ranker)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"   // or mongodb if you prefer
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  subcategories SubCategory[]
}

model SubCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  categoryId  String
  createdAt   DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id])
  exams    Exam[]
}

model Exam {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  subCategoryId String
  createdAt     DateTime @default(now())

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])
  testSeries  TestSeries[]
}

model TestSeries {
  id        String   @id @default(cuid())
  title     String
  price     Float
  examId    String
  createdAt DateTime @default(now())

  exam  Exam   @relation(fields: [examId], references: [id])
  tests Test[]
}

model Test {
  id           String   @id @default(cuid())
  title        String
  duration     Int      // minutes
  totalMarks   Int
  testSeriesId String
  createdAt    DateTime @default(now())

  testSeries TestSeries @relation(fields: [testSeriesId], references: [id])
  questions  Question[]
  attempts   Attempt[]
}

model Question {
  id        String   @id @default(cuid())
  question  String
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  correct   String
  marks     Int
  testId    String

  test Test @relation(fields: [testId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  attempts Attempt[]
}

model Attempt {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  score     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  test Test @relation(fields: [testId], references: [id])
}
🧠 Database Relationship Diagram
Category
   │
   └── SubCategory
          │
          └── Exam
                │
                └── TestSeries
                        │
                        └── Test
                              │
                              └── Question
User side:

User
  │
  └── Attempt
         │
         └── Test
